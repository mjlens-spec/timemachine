page {
  background: #f7f7f9;
  color: #1a1a1a;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  padding: 32rpx;
}

button.btn-primary {
  background: #07c160;
  color: white;
  border-radius: 12rpx;
}

button.btn-secondary {
  background: white;
  color: #1a1a1a;
  border-radius: 12rpx;
}

button[disabled] {
  opacity: 0.6;
}
