.card {
  background: white;
  border-radius: 16rpx;
  padding: 28rpx;
  border-left: 8rpx solid #07c160;
}

.card.wrong {
  border-left-color: #fa5151;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.number {
  font-weight: 600;
  color: #555;
}

.badge {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.badge-ok {
  background: #e8f7ee;
  color: #07c160;
}

.badge-err {
  background: #ffeaea;
  color: #fa5151;
}

.stem {
  margin: 16rpx 0;
  line-height: 1.6;
}

.row {
  display: flex;
  margin-top: 12rpx;
  font-size: 26rpx;
}

.label {
  color: #888;
  width: 140rpx;
  flex-shrink: 0;
}

.value {
  flex: 1;
}

.value-ok {
  color: #07c160;
  font-weight: 600;
}

.value-err {
  color: #fa5151;
}

.warn {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #ff8c00;
}
