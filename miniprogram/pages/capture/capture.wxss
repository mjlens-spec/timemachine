.preview {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.preview-img {
  width: 100%;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  line-height: 160rpx;
  margin: 0 auto;
  font-size: 100rpx;
  color: #ccc;
  border: 4rpx dashed #ccc;
  border-radius: 24rpx;
}

.empty-text {
  margin: 32rpx 0;
  color: #888;
}

.actions {
  margin-top: 32rpx;
}

.actions .big,
.empty .big {
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
}
