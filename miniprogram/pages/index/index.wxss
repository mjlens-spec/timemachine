.hero {
  padding: 80rpx 0 60rpx 0;
  text-align: center;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 16rpx;
  color: #888;
  font-size: 28rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin: 32rpx 0;
}

.actions .big {
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
}

.tips {
  margin-top: 64rpx;
  padding: 32rpx;
  background: white;
  border-radius: 16rpx;
}

.tip-title {
  font-weight: 600;
  margin-bottom: 16rpx;
}

.tip-item {
  margin-top: 12rpx;
  color: #555;
  line-height: 1.6;
}
