.summary {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.subject {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.score-row {
  display: flex;
  justify-content: space-around;
}

.score-item {
  text-align: center;
}

.score-num {
  font-size: 56rpx;
  font-weight: 700;
}

.score-num.ok {
  color: #07c160;
}

.score-num.err {
  color: #fa5151;
}

.score-label {
  color: #888;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.score-final {
  margin-top: 24rpx;
  text-align: center;
  color: #555;
}

.score-final-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.questions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.actions {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: #888;
}
